-- ============================================
-- USER AUTHENTICATION
-- ============================================

-- Login procedure
CREATE OR ALTER PROCEDURE sp_UserLogin
    @Username NVARCHAR(50),
    @PasswordHash NVARCHAR(255),
    @IPAddress NVARCHAR(50) = NULL,
    @UserAgent NVARCHAR(500) = NULL
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @UserID INT;
    DECLARE @IsActive BIT;
    DECLARE @StoredPasswordHash NVARCHAR(255);
    DECLARE @PasswordSalt NVARCHAR(255);
    DECLARE @SessionToken NVARCHAR(255);
    DECLARE @ComputedHash NVARCHAR(255);
    DECLARE @FailedAttempts INT;
    DECLARE @SessionExpiryDate DATETIME;

   BEGIN TRY

-- ============================================
        -- STEP 1: CHECK FOR ACCOUNT LOCKOUT
        -- Prevent brute force attacks by limiting failed attempts
        -- ============================================
        SELECT @FailedAttempts = COUNT(*)
        FROM FailedLoginAttempts
        WHERE Username = @Username
          AND AttemptDate > DATEADD(MINUTE, -15, GETDATE());
        
        IF @FailedAttempts >= 5
        BEGIN
            -- Log lockout attempt
            INSERT INTO AuditLog (UserID, Action, IPAddress, Details)
            VALUES (NULL, 'LOGIN_BLOCKED_LOCKOUT', @IPAddress, 
                    'User: ' + @Username + ' - Too many failed attempts');
            
            SELECT 
                0 AS Success, 
                'Account temporarily locked due to multiple failed login attempts. Please try again in 15 minutes.' AS Message;
            RETURN;
        END
        
    -- Validate user credentials
    SELECT 
        @UserID = UserID,
        @IsActive = IsActive
    FROM Users
    WHERE Username = @Username 
        AND PasswordHash = @PasswordHash;


    
    IF @UserID IS NULL
    BEGIN
        -- Invalid credentials
        SELECT 0 AS Success, 'Invalid username or password' AS Message;
        RETURN;
    END
    
    IF @IsActive = 0
    BEGIN
        -- User account is inactive
        SELECT 0 AS Success, 'User account is inactive' AS Message;
        RETURN;
    END
    
    -- Generate session token
    SET @SessionToken = CONVERT(NVARCHAR(255), NEWID());
    
    -- Create session
    INSERT INTO UserSessions (UserID, SessionToken, IPAddress, UserAgent)
    VALUES (@UserID, @SessionToken, @IPAddress, @UserAgent);
    
    -- Update last login date
    UPDATE Users
    SET LastLoginDate = GETDATE()
    WHERE UserID = @UserID;
    
    -- Return success with user details
    SELECT 
        1 AS Success,
        'Login successful' AS Message,
        @SessionToken AS SessionToken,
        u.UserID,
        u.Username,
        u.FirstName,
        u.LastName,
        u.Email,
        u.Role
    FROM Users u
    WHERE u.UserID = @UserID;
END
GO

-- Logout procedure
CREATE OR ALTER PROCEDURE sp_UserLogout
    @SessionToken NVARCHAR(255)
AS
BEGIN
    SET NOCOUNT ON;
    
    UPDATE UserSessions
    SET 
        IsActive = 0,
        LogoutDate = GETDATE()
    WHERE SessionToken = @SessionToken
        AND IsActive = 1;
    
    SELECT 1 AS Success, 'Logout successful' AS Message;
END
GO
-- ============================================
        -- STEP 2: RETRIEVE USER CREDENTIALS
        -- Get stored password hash and salt for verification
        -- ============================================
        SELECT 
            @UserID = UserID,
            @IsActive = IsActive,
            @StoredPasswordHash = PasswordHash,
            @PasswordSalt = PasswordSalt
        FROM Users
        WHERE Username = @Username;
        
        -- Check if user exists
        IF @UserID IS NULL
        BEGIN
            -- Record failed attempt (prevents username enumeration by using generic message)
            INSERT INTO FailedLoginAttempts (Username, IPAddress)
            VALUES (@Username, @IPAddress);
            
            INSERT INTO AuditLog (UserID, Action, IPAddress, Details)
            VALUES (NULL, 'LOGIN_FAILED_INVALID_USER', @IPAddress, 'Username: ' + @Username);
            
            -- Generic error message to prevent username enumeration
            SELECT 0 AS Success, 'Invalid username or password' AS Message;
            RETURN;
        END
        
        -- ============================================
        -- STEP 3: VERIFY PASSWORD
        -- Compute hash with salt and compare with stored hash
        -- ============================================
        -- Compute hash using SHA2_512 with salt
        SET @ComputedHash = CONVERT(NVARCHAR(255), 
            HASHBYTES('SHA2_512', @Password + ISNULL(@PasswordSalt, '')), 2);
        
        IF @ComputedHash != @StoredPasswordHash
        BEGIN
            -- Record failed attempt
            INSERT INTO FailedLoginAttempts (Username, IPAddress)
            VALUES (@Username, @IPAddress);
            
            INSERT INTO AuditLog (UserID, Action, IPAddress, Details)
            VALUES (@UserID, 'LOGIN_FAILED_INVALID_PASSWORD', @IPAddress, NULL);
            
            SELECT 0 AS Success, 'Invalid username or password' AS Message;
            RETURN;
        END
        
        -- ============================================
        -- STEP 4: CHECK ACCOUNT STATUS
        -- Ensure user account is active
        -- ============================================
        IF @IsActive = 0
        BEGIN
            INSERT INTO AuditLog (UserID, Action, IPAddress, Details)
            VALUES (@UserID, 'LOGIN_FAILED_INACTIVE_ACCOUNT', @IPAddress, NULL);
            
            SELECT 0 AS Success, 'Your account is inactive. Please contact support for assistance.' AS Message;
            RETURN;
        END
        
        -- ============================================
        -- STEP 5: CLEAR FAILED LOGIN ATTEMPTS
        -- Successful login - remove previous failed attempts
        -- ============================================
        DELETE FROM FailedLoginAttempts
        WHERE Username = @Username;
        
        -- ============================================
        -- STEP 6: INVALIDATE EXISTING SESSIONS
        -- Optional: Expire any active sessions for this user
        -- Uncomment if you want single-session-per-user policy
        -- ============================================
        UPDATE UserSessions
        SET IsActive = 0, LogoutDate = GETDATE()
        WHERE UserID = @UserID AND IsActive = 1;
        
        -- ============================================
        -- STEP 7: GENERATE SECURE SESSION TOKEN
        -- Create cryptographically secure session identifier
        -- ============================================
        SET @SessionToken = CONVERT(NVARCHAR(255), 
            HASHBYTES('SHA2_256', 
                CAST(NEWID() AS NVARCHAR(36)) + 
                CAST(GETDATE() AS NVARCHAR(50)) + 
                @Username + 
                ISNULL(@IPAddress, '')
            ), 2);
        
        -- Set session expiry (24 hours from now)
        SET @SessionExpiryDate = DATEADD(HOUR, 24, GETDATE());
        
        -- ============================================
        -- STEP 8: CREATE NEW SESSION
        -- Store session details in database
        -- ============================================
        INSERT INTO UserSessions (UserID, SessionToken, IPAddress, UserAgent, ExpiryDate, IsActive, LoginDate)
        VALUES (@UserID, @SessionToken, @IPAddress, @UserAgent, @SessionExpiryDate, 1, GETDATE());
        
        -- ============================================
        -- STEP 9: UPDATE LAST LOGIN DATE
        -- Track user login activity
        -- ============================================
        UPDATE Users
        SET LastLoginDate = GETDATE()
        WHERE UserID = @UserID;
        
        -- ============================================
        -- STEP 10: LOG SUCCESSFUL LOGIN
        -- Create audit trail
        -- ============================================
        INSERT INTO AuditLog (UserID, Action, IPAddress, Details)
        VALUES (@UserID, 'LOGIN_SUCCESS', @IPAddress, 'Session created successfully');
        
        -- ============================================
        -- STEP 11: RETURN SUCCESS WITH USER DETAILS
        -- Send session token and user information to client
        -- ============================================
        SELECT
            1 AS Success,
            'Login successful' AS Message,
            @SessionToken AS SessionToken,
            @SessionExpiryDate AS ExpiryDate,
            u.UserID,
            u.Username,
            u.FirstName,
            u.LastName,
            u.Email,
            u.Role
        FROM Users u
        WHERE u.UserID = @UserID;
        
    END TRY
    BEGIN CATCH
        -- ============================================
        -- ERROR HANDLING
        -- Log error and return generic error message
        -- ============================================
        INSERT INTO ErrorLog (ErrorMessage, ErrorProcedure, ErrorLine)
        VALUES (
            ERROR_MESSAGE(),
            ERROR_PROCEDURE(),
            ERROR_LINE()
        );
        
        -- Return error to client without exposing internal details
        SELECT 
            0 AS Success, 
            'An error occurred during login. Please try again or contact support if the problem persists.' AS Message;
    END CATCH
END
GO
-- ============================================
-- STORED PROCEDURE: VALIDATE SESSION
-- Purpose: Verify session token is valid and not expired
-- Used by: All protected endpoints in the application
-- Security Features:
--   - Token validation
--   - Expiry checking
--   - Automatic session cleanup
-- ============================================
CREATE OR ALTER PROCEDURE sp_ValidateSession
    @SessionToken NVARCHAR(255)
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @UserID INT;
    DECLARE @IsActive BIT;
    DECLARE @ExpiryDate DATETIME;
    
    BEGIN TRY
        -- Retrieve session details
        SELECT 
            @UserID = us.UserID,
            @IsActive = us.IsActive,
            @ExpiryDate = us.ExpiryDate
        FROM UserSessions us
        WHERE us.SessionToken = @SessionToken;
        
        -- Check if session exists
        IF @UserID IS NULL
        BEGIN
            SELECT 0 AS IsValid, 'Session not found' AS Message;
            RETURN;
        END
        
        -- Check if session is active
        IF @IsActive = 0
        BEGIN
            SELECT 0 AS IsValid, 'Session has been terminated' AS Message;
            RETURN;
        END
        
        -- Check if session has expired
        IF @ExpiryDate < GETDATE()
        BEGIN
            -- Automatically expire the session
            UPDATE UserSessions
            SET IsActive = 0, LogoutDate = GETDATE()
            WHERE SessionToken = @SessionToken;
            
            -- Log session expiry
            INSERT INTO AuditLog (UserID, Action, IPAddress, Details)
            SELECT 
                @UserID, 
                'SESSION_EXPIRED', 
                IPAddress, 
                'Session expired automatically'
            FROM UserSessions
            WHERE SessionToken = @SessionToken;
            
            SELECT 0 AS IsValid, 'Session has expired. Please log in again.' AS Message;
            RETURN;
        END
        
        -- Session is valid - return user details
        SELECT 
            1 AS IsValid,
            'Session is valid' AS Message,
            u.UserID,
            u.Username,
            u.FirstName,
            u.LastName,
            u.Email,
            u.Role,
            @ExpiryDate AS ExpiryDate
        FROM Users u
        WHERE u.UserID = @UserID;
        
    END TRY
    BEGIN CATCH
        -- Log error
        INSERT INTO ErrorLog (ErrorMessage, ErrorProcedure, ErrorLine)
        VALUES (
            ERROR_MESSAGE(),
            ERROR_PROCEDURE(),
            ERROR_LINE()
        );
        
        SELECT 0 AS IsValid, 'An error occurred during session validation' AS Message;
    END CATCH
END
GO
-- ============================================
-- UTILITY PROCEDURE: CLEANUP EXPIRED SESSIONS
-- Purpose: Remove expired sessions and old failed login attempts
-- Recommended: Run this as a scheduled job (daily)
-- ============================================
CREATE OR ALTER PROCEDURE sp_CleanupExpiredSessions
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @DeletedSessions INT;
    DECLARE @DeletedAttempts INT;
    
    BEGIN TRY
        -- Deactivate expired sessions
        UPDATE UserSessions
        SET IsActive = 0, LogoutDate = GETDATE()
        WHERE IsActive = 1
          AND ExpiryDate < GETDATE();
        
        SET @DeletedSessions = @@ROWCOUNT;
        
        -- Delete old failed login attempts (older than 7 days)
        DELETE FROM FailedLoginAttempts
        WHERE AttemptDate < DATEADD(DAY, -7, GETDATE());
        
        SET @DeletedAttempts = @@ROWCOUNT;
        
        -- Log cleanup activity
        INSERT INTO AuditLog (UserID, Action, IPAddress, Details)
        VALUES (NULL, 'CLEANUP_EXECUTED', NULL, 
                'Expired sessions: ' + CAST(@DeletedSessions AS NVARCHAR(10)) + 
                ', Failed attempts removed: ' + CAST(@DeletedAttempts AS NVARCHAR(10)));
        
        SELECT 
            1 AS Success, 
            'Cleanup completed' AS Message,
            @DeletedSessions AS ExpiredSessionsCleaned,
            @DeletedAttempts AS FailedAttemptsRemoved;
        
    END TRY
    BEGIN CATCH
        INSERT INTO ErrorLog (ErrorMessage, ErrorProcedure, ErrorLine)
        VALUES (
            ERROR_MESSAGE(),
            ERROR_PROCEDURE(),
            ERROR_LINE()
        );
        
        SELECT 0 AS Success, 'Cleanup failed' AS Message;
    END CATCH
END
GO

-- ============================================
-- UTILITY PROCEDURE: CREATE NEW USER (HELPER)
-- Purpose: Create a new user with secure password hashing
-- Used by: Admin panel or registration system
-- ============================================
CREATE OR ALTER PROCEDURE sp_CreateUser
    @Username NVARCHAR(50),
    @Password NVARCHAR(255),
    @FirstName NVARCHAR(50),
    @LastName NVARCHAR(50),
    @Email NVARCHAR(100),
    @Role NVARCHAR(20) = 'Customer'
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @PasswordSalt NVARCHAR(255);
    DECLARE @PasswordHash NVARCHAR(255);
    DECLARE @NewUserID INT;
    
    BEGIN TRY
        -- Check if username already exists
        IF EXISTS (SELECT 1 FROM Users WHERE Username = @Username)
        BEGIN
            SELECT 0 AS Success, 'Username already exists' AS Message;
            RETURN;
        END
        
        -- Check if email already exists
        IF EXISTS (SELECT 1 FROM Users WHERE Email = @Email)
        BEGIN
            SELECT 0 AS Success, 'Email already registered' AS Message;
            RETURN;
        END
        
        -- Generate random salt
        SET @PasswordSalt = CONVERT(NVARCHAR(255), NEWID());
        
        -- Hash password with salt
        SET @PasswordHash = CONVERT(NVARCHAR(255), 
            HASHBYTES('SHA2_512', @Password + @PasswordSalt), 2);
        
        -- Insert new user
        INSERT INTO Users (Username, PasswordHash, PasswordSalt, FirstName, LastName, Email, Role, IsActive, CreatedDate)
        VALUES (@Username, @PasswordHash, @PasswordSalt, @FirstName, @LastName, @Email, @Role, 1, GETDATE());
        
        SET @NewUserID = SCOPE_IDENTITY();
        
        -- Log user creation
        INSERT INTO AuditLog (UserID, Action, IPAddress, Details)
        VALUES (@NewUserID, 'USER_CREATED', NULL, 'New user account created');
        
        SELECT 
            1 AS Success, 
            'User created successfully' AS Message,
            @NewUserID AS UserID;
        
    END TRY
    BEGIN CATCH
        INSERT INTO ErrorLog (ErrorMessage, ErrorProcedure, ErrorLine)
        VALUES (
            ERROR_MESSAGE(),
            ERROR_PROCEDURE(),
            ERROR_LINE()
        );
        
        SELECT 0 AS Success, 'An error occurred while creating user' AS Message;
    END CATCH
END
