-- ============================================
-- GET INVENTORY
-- Returns inventory with stock status
-- ============================================
CREATE OR ALTER PROCEDURE sp_GetInventory
    @ProductID INT = NULL,
    @LowStockOnly BIT = 0
AS
BEGIN
    SET NOCOUNT ON;
    
    SELECT 
        i.InventoryID,
        i.ProductID,
        p.ProductCode,
        p.ProductName,
        p.Category,
        i.QuantityInStock,
        i.QuantityReserved,
        i.QuantityAvailable,
        p.MinimumStockLevel,
        p.ReorderLevel,
        p.UnitPrice,
        (i.QuantityInStock * p.UnitPrice) AS TotalValue,
        CASE 
            WHEN i.QuantityInStock <= p.MinimumStockLevel THEN 'Low'
            WHEN i.QuantityInStock <= p.ReorderLevel THEN 'Medium'
            ELSE 'High'
        END AS StockStatus,
        i.Location,
        i.LastStockCheck,
        i.LastUpdatedDate
    FROM Inventory i
    INNER JOIN Products p ON i.ProductID = p.ProductID
    WHERE (@ProductID IS NULL OR i.ProductID = @ProductID)
      AND (@LowStockOnly = 0 OR i.QuantityInStock <= p.MinimumStockLevel)
      AND p.IsActive = 1
    ORDER BY 
        CASE WHEN i.QuantityInStock <= p.MinimumStockLevel THEN 1
             WHEN i.QuantityInStock <= p.ReorderLevel THEN 2
             ELSE 3 END,
        p.ProductName;
END
GO

-- ============================================
-- ADD INWARD TRANSACTION
-- Records stock received from supplier
-- ============================================
CREATE OR ALTER PROCEDURE sp_AddInwardTransaction
    @ProductID INT,
    @SupplierID INT,
    @Quantity INT,
    @UnitCost DECIMAL(10,2),
    @ReferenceNumber NVARCHAR(100) = NULL,
    @InvoiceNumber NVARCHAR(100) = NULL,
    @BatchNumber NVARCHAR(100) = NULL,
    @Notes NVARCHAR(MAX) = NULL,
    @ReceivedBy INT,
    @AutoApprove BIT = 0
AS
BEGIN
    SET NOCOUNT ON;
    
    BEGIN TRY
        BEGIN TRANSACTION;
        
        DECLARE @InwardID INT;
        DECLARE @TransactionNumber NVARCHAR(50) = 
            'INW-' + FORMAT(GETDATE(), 'yyyyMMdd') + '-' + 
            RIGHT('00000' + CAST(NEXT VALUE FOR seq_InwardTransaction AS NVARCHAR), 5);
        
        -- Insert transaction
        INSERT INTO InwardTransactions (
            TransactionNumber, ProductID, SupplierID, Quantity, UnitCost,
            ReferenceNumber, InvoiceNumber, BatchNumber, Notes, ReceivedBy,
            Status
        )
        VALUES (
            @TransactionNumber, @ProductID, @SupplierID, @Quantity, @UnitCost,
            @ReferenceNumber, @InvoiceNumber, @BatchNumber, @Notes, @ReceivedBy,
            CASE WHEN @AutoApprove = 1 THEN 'Approved' ELSE 'Pending' END
        );
        
        SET @InwardID = SCOPE_IDENTITY();
        
        -- Update inventory if auto-approved
        IF @AutoApprove = 1
        BEGIN
            UPDATE Inventory
            SET QuantityInStock = QuantityInStock + @Quantity,
                LastUpdatedDate = GETDATE(),
                LastUpdatedBy = @ReceivedBy
            WHERE ProductID = @ProductID;
            
            -- Create inventory record if doesn't exist
            IF @@ROWCOUNT = 0
                INSERT INTO Inventory (ProductID, QuantityInStock, LastUpdatedBy)
                VALUES (@ProductID, @Quantity, @ReceivedBy);
        END
        
        EXEC sp_LogAudit 'InwardTransactions', @InwardID, 'INSERT', @ReceivedBy;
        
        COMMIT TRANSACTION;
        
        SELECT 1 AS Success, 
               'Inward transaction recorded' AS Message,
               @InwardID AS InwardID,
               @TransactionNumber AS TransactionNumber;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        
        INSERT INTO ErrorLog (ErrorMessage, ErrorProcedure, ErrorLine)
        VALUES (ERROR_MESSAGE(), ERROR_PROCEDURE(), ERROR_LINE());
        
        SELECT 0 AS Success, ERROR_MESSAGE() AS Message;
    END CATCH
END
GO

-- ============================================
-- ADD OUTWARD TRANSACTION
-- Records stock dispatched to customer
-- ============================================
CREATE OR ALTER PROCEDURE sp_AddOutwardTransaction
    @ProductID INT,
    @Quantity INT,
    @UnitPrice DECIMAL(10,2) = NULL,
    @Reason NVARCHAR(50),
    @CustomerName NVARCHAR(200) = NULL,
    @ReferenceNumber NVARCHAR(100) = NULL,
    @OrderNumber NVARCHAR(100) = NULL,
    @Notes NVARCHAR(MAX) = NULL,
    @DispatchedBy INT,
    @AutoApprove BIT = 0
AS
BEGIN
    SET NOCOUNT ON;
    
    BEGIN TRY
        BEGIN TRANSACTION;
        
        DECLARE @OutwardID INT;
        DECLARE @CurrentStock INT;
        
        -- Validate stock availability
        SELECT @CurrentStock = QuantityAvailable,
               @UnitPrice = ISNULL(@UnitPrice, p.UnitPrice)
        FROM Inventory i
        INNER JOIN Products p ON i.ProductID = p.ProductID
        WHERE i.ProductID = @ProductID;
        
        IF @CurrentStock IS NULL OR @CurrentStock < @Quantity
        BEGIN
            ROLLBACK TRANSACTION;
            SELECT 0 AS Success, 
                   'Insufficient stock' AS Message,
                   ISNULL(@CurrentStock, 0) AS CurrentStock;
            RETURN;
        END
        
        DECLARE @TransactionNumber NVARCHAR(50) = 
            'OUT-' + FORMAT(GETDATE(), 'yyyyMMdd') + '-' + 
            RIGHT('00000' + CAST(NEXT VALUE FOR seq_OutwardTransaction AS NVARCHAR), 5);
        
        -- Insert transaction
        INSERT INTO OutwardTransactions (
            TransactionNumber, ProductID, Quantity, UnitPrice, Reason,
            CustomerName, ReferenceNumber, OrderNumber, Notes, DispatchedBy,
            Status
        )
        VALUES (
            @TransactionNumber, @ProductID, @Quantity, @UnitPrice, @Reason,
            @CustomerName, @ReferenceNumber, @OrderNumber, @Notes, @DispatchedBy,
            CASE WHEN @AutoApprove = 1 THEN 'Approved' ELSE 'Pending' END
        );
        
        SET @OutwardID = SCOPE_IDENTITY();
        
        -- Update inventory if auto-approved
        IF @AutoApprove = 1
            UPDATE Inventory
            SET QuantityInStock = QuantityInStock - @Quantity,
                LastUpdatedDate = GETDATE(),
                LastUpdatedBy = @DispatchedBy
            WHERE ProductID = @ProductID;
        
        EXEC sp_LogAudit 'OutwardTransactions', @OutwardID, 'INSERT', @DispatchedBy;
        
        COMMIT TRANSACTION;
        
        SELECT 1 AS Success,
               'Outward transaction recorded' AS Message,
               @OutwardID AS OutwardID,
               @TransactionNumber AS TransactionNumber;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        
        INSERT INTO ErrorLog (ErrorMessage, ErrorProcedure, ErrorLine)
        VALUES (ERROR_MESSAGE(), ERROR_PROCEDURE(), ERROR_LINE());
        
        SELECT 0 AS Success, ERROR_MESSAGE() AS Message;
    END CATCH
END
GO

-- ============================================
-- CREATE PURCHASE ORDER
-- Generates PO with line items (JSON input)
-- ============================================
CREATE OR ALTER PROCEDURE sp_CreatePurchaseOrder
    @SupplierID INT,
    @ExpectedDeliveryDate DATE = NULL,
    @Notes NVARCHAR(MAX) = NULL,
    @CreatedBy INT,
    @OrderDetails NVARCHAR(MAX) -- JSON: [{ProductID, Quantity, UnitPrice}]
AS
BEGIN
    SET NOCOUNT ON;
    
    BEGIN TRY
        BEGIN TRANSACTION;
        
        DECLARE @OrderID INT;
        DECLARE @OrderNumber NVARCHAR(50) = 
            'PO-' + FORMAT(GETDATE(), 'yyyyMMdd') + '-' + 
            RIGHT('00000' + CAST(NEXT VALUE FOR seq_PurchaseOrder AS NVARCHAR), 5);
        
        -- Create order header
        INSERT INTO PurchaseOrders (OrderNumber, SupplierID, ExpectedDeliveryDate, Notes, CreatedBy)
        VALUES (@OrderNumber, @SupplierID, @ExpectedDeliveryDate, @Notes, @CreatedBy);
        
        SET @OrderID = SCOPE_IDENTITY();
        
        -- Insert order details from JSON
        INSERT INTO PurchaseOrderDetails (OrderID, ProductID, Quantity, UnitPrice)
        SELECT @OrderID,
               JSON_VALUE(value, '$.ProductID'),
               JSON_VALUE(value, '$.Quantity'),
               JSON_VALUE(value, '$.UnitPrice')
        FROM OPENJSON(@OrderDetails);
        
        -- Update total amount
        UPDATE PurchaseOrders
        SET TotalAmount = (SELECT SUM(TotalPrice) FROM PurchaseOrderDetails WHERE OrderID = @OrderID)
        WHERE OrderID = @OrderID;
        
        EXEC sp_LogAudit 'PurchaseOrders', @OrderID, 'INSERT', @CreatedBy;
        
        COMMIT TRANSACTION;
        
        SELECT 1 AS Success,
               'Purchase order created' AS Message,
               @OrderID AS OrderID,
               @OrderNumber AS OrderNumber;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        
        INSERT INTO ErrorLog (ErrorMessage, ErrorProcedure, ErrorLine)
        VALUES (ERROR_MESSAGE(), ERROR_PROCEDURE(), ERROR_LINE());
        
        SELECT 0 AS Success, ERROR_MESSAGE() AS Message;
    END CATCH
END
GO

-- ============================================
-- RECEIVE PURCHASE ORDER
-- Marks PO as received, updates inventory
-- ============================================
CREATE OR ALTER PROCEDURE sp_ReceivePurchaseOrder
    @OrderID INT,
    @ReceivedBy INT
AS
BEGIN
    SET NOCOUNT ON;
    
    BEGIN TRY
        BEGIN TRANSACTION;
        
        DECLARE @SupplierID INT, @OrderNumber NVARCHAR(50);
        
        -- Validate order exists
        SELECT @SupplierID = SupplierID, @OrderNumber = OrderNumber
        FROM PurchaseOrders
        WHERE OrderID = @OrderID;
        
        IF @OrderNumber IS NULL
        BEGIN
            ROLLBACK TRANSACTION;
            SELECT 0 AS Success, 'Order not found' AS Message;
            RETURN;
        END
        
        -- Create inward transactions
        INSERT INTO InwardTransactions (
            TransactionNumber, ProductID, SupplierID, Quantity, UnitCost,
            ReferenceNumber, ReceivedBy, Status
        )
        SELECT 
            'INW-' + @OrderNumber + '-' + CAST(od.OrderDetailID AS NVARCHAR),
            od.ProductID, @SupplierID, od.Quantity, od.UnitPrice,
            @OrderNumber, @ReceivedBy, 'Approved'
        FROM PurchaseOrderDetails od
        WHERE od.OrderID = @OrderID;
        
        -- Update inventory
        UPDATE i
        SET QuantityInStock = i.QuantityInStock + od.Quantity,
            LastUpdatedDate = GETDATE(),
            LastUpdatedBy = @ReceivedBy
        FROM Inventory i
        INNER JOIN PurchaseOrderDetails od ON i.ProductID = od.ProductID
        WHERE od.OrderID = @OrderID;
        
        -- Update order
        UPDATE PurchaseOrders
        SET Status = 'Received',
            ActualDeliveryDate = CAST(GETDATE() AS DATE),
            ModifiedBy = @ReceivedBy,
            ModifiedDate = GETDATE()
        WHERE OrderID = @OrderID;
        
        -- Update order details
        UPDATE PurchaseOrderDetails
        SET QuantityReceived = Quantity
        WHERE OrderID = @OrderID;
        
        EXEC sp_LogAudit 'PurchaseOrders', @OrderID, 'RECEIVE', @ReceivedBy;
        
        COMMIT TRANSACTION;
        
        SELECT 1 AS Success, 'Order received, inventory updated' AS Message;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        
        INSERT INTO ErrorLog (ErrorMessage, ErrorProcedure, ErrorLine)
        VALUES (ERROR_MESSAGE(), ERROR_PROCEDURE(), ERROR_LINE());
        
        SELECT 0 AS Success, ERROR_MESSAGE() AS Message;
    END CATCH
END
GO

